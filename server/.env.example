# Copy this file to .env and adjust as needed.
#   Windows CMD:  copy server\.env.example server\.env
#   macOS/Linux:  cp server/.env.example server/.env

# Runtime
NODE_ENV=development
PORT=4000

# Database — local Docker MySQL 8 (see docker-compose.yml)
DATABASE_URL=mysql://root:root@localhost:3306/dih_dev

# Auth (Sprint 2 — DIH-1). Generate a real secret before use; never commit it.
JWT_SECRET=change-me-in-local-only-never-commit
JWT_EXPIRY=24h

# Logging — info | debug | warn | error
LOG_LEVEL=info

# CORS — the Vite dev server origin
CLIENT_ORIGIN=http://localhost:5173
